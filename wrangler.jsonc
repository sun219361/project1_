{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "meetup-korea",
  "compatibility_date": "2024-01-01",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "placeholder_kv_id",
      "preview_id": "placeholder_kv_preview_id"
    }
  ]
}
