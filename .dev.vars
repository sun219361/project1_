# ════════════════════════════════════════════════════════════
#  .dev.vars  —  Cloudflare Pages 로컬 개발용 환경변수
#
#  ⚠️  이 파일은 .gitignore에 등록되어 있어 GitHub에 올라가지 않습니다
#  ⚠️  절대 커밋하지 마세요!
#
#  사용법:
#    - 이 파일을 프로젝트 루트에 두면 wrangler pages dev 실행 시 자동으로 읽힘
#    - 실제 배포 시에는 Cloudflare 대시보드 or wrangler secret put 명령어 사용
#
#  Cloudflare 배포 시 시크릿 등록 방법:
#    npx wrangler pages secret put KAKAO_MAP_KEY --project-name meetup-korea
#    npx wrangler pages secret put ODSAY_API_KEY --project-name meetup-korea
# ════════════════════════════════════════════════════════════

# ── 카카오맵 API 키 ────────────────────────────────────────
# 발급: https://developers.kakao.com → 내 애플리케이션 → JavaScript 키
KAKAO_MAP_KEY=여기에_카카오_JavaScript_앱_키_입력

# ── ODsay 대중교통 API 키 ──────────────────────────────────
# 발급: https://lab.odsay.com → 회원가입 → API 키 발급 (무료)
ODSAY_API_KEY=여기에_ODsay_API_키_입력

# ── 앱 설정 ───────────────────────────────────────────────
# 로컬 개발 서버 포트
PORT=3000
NODE_ENV=development
