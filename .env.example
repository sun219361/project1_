# ════════════════════════════════════════════════════════════
#  .env.example  —  환경변수 템플릿 (이 파일은 GitHub에 올려도 됩니다)
#
#  사용법:
#    cp .env.example .dev.vars     ← 이 파일을 복사해서 .dev.vars 만들기
#    그 다음 실제 값을 채워넣으세요
# ════════════════════════════════════════════════════════════

# ── 카카오맵 API 키 ────────────────────────────────────────
# 발급: https://developers.kakao.com
# 1. 로그인 → 내 애플리케이션 → 애플리케이션 추가
# 2. 앱 키 탭 → JavaScript 키 복사
# 3. 플랫폼 → Web → 사이트 도메인 등록 (본인 도메인)
KAKAO_MAP_KEY=your_kakao_javascript_app_key_here

# ── ODsay 대중교통 API 키 ──────────────────────────────────
# 발급: https://lab.odsay.com
# 1. 회원가입 후 로그인
# 2. API 키 발급 (무료, 일 1000회 제한)
ODSAY_API_KEY=your_odsay_api_key_here

# ── 앱 환경 설정 ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ════════════════════════════════════════════════════════════
#  Cloudflare 배포 시 환경변수 등록 방법
#  (아래 명령어들을 터미널에서 하나씩 실행)
# ════════════════════════════════════════════════════════════
#
#  npx wrangler pages secret put KAKAO_MAP_KEY --project-name meetup-korea
#  npx wrangler pages secret put ODSAY_API_KEY --project-name meetup-korea
#
#  등록 확인:
#  npx wrangler pages secret list --project-name meetup-korea
# ════════════════════════════════════════════════════════════
